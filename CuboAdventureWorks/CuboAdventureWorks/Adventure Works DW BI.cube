  <Kpis>
    <Kpi dwd:design-time-name="8da6dbef-1a15-48ad-9036-0c13052c488a">
      <ID>KPI</ID>
      <Name>Ventas KPI</Name>
      <AssociatedMeasureGroupID>Fact Internet Sales</AssociatedMeasureGroupID>
      <Value>[Measures].[Sales Amount]</Value>
      <Goal>[Measures].[Sales Amount] * 1.1</Goal>
      <Status>CASE 
WHEN IsEmpty([Measures].[Sales Amount]) THEN NULL
WHEN [Measures].[Sales Amount] &gt; 6000000 THEN 1
WHEN [Measures].[Sales Amount] &gt; 3000000 THEN 0
ELSE -1
END</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Gauge - Ascending</StatusGraphic>
    </Kpi>
  </Kpis>
